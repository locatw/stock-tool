{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Read(.vscode)",
      "Edit(.vscode)",
      "Write(.vscode)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:jpx.gitbook.io)",
      "WebFetch(domain:jpx-jquants.com)",
      "WebFetch(domain:redocly.com)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-go.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-go-conventions.sh",
            "timeout": 180,
            "async": true
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/lint-api.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gen-api.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/test-go.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-markdown-conventions.sh",
            "timeout": 180,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "enabledMcpjsonServers": ["fetch", "aws-docs", "postgres"]
}
